{
  "name": "@docbrain/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "node --env-file=../../.env.local ./node_modules/tsx/dist/cli.mjs watch --tsconfig tsconfig.json src/main.ts",
    "build": "nest build -p tsconfig.build.json",
    "start": "node --env-file=../../.env.local dist/apps/api/src/main.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@docbrain/config": "workspace:*",
    "@docbrain/types": "workspace:*",
    "@docbrain/validators": "workspace:*",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-fastify": "^11.1.3",
    "@nestjs/terminus": "^11.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "latest",
    "cheerio": "^1.2.0",
    "openai": "^6.42.0",
    "p-limit": "^7.3.0",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "turndown": "^7.2.4",
    "zod": "^3.25.64"
  },
  "prisma": {
    "seed": "tsx ../../prisma/seed.ts"
  },
  "devDependencies": {
    "@docbrain/eslint-config": "workspace:*",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.3",
    "@types/node": "^24.0.1",
    "@types/pg": "^8.20.0",
    "@types/turndown": "^5.0.6",
    "dotenv": "^17.4.2",
    "eslint": "^9.28.0",
    "prisma": "7.8.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.3"
  }
}
