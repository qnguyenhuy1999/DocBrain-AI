{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "noEmit": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "paths": {
      "@docbrain/types": ["../../packages/types/src"],
      "@docbrain/validators": ["../../packages/validators/src"],
      "@docbrain/config": ["../../packages/config/src"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
